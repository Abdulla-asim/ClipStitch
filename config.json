{
  "llm": {
    "provider": "openai",
    "model": "gpt-4o-mini",
    "ollama_host": "http://localhost:11434",
    "ollama_model": "llama3"
  },
  "monitor": {
    "session_gap_minutes": 30,
    "dedup_window": 5
  },
  "privacy": {
    "redact_api_keys": true,
    "redact_passwords": true,
    "redact_emails": false
  },
  "web": {
    "port": 5050,
    "open_on_start": false
  },
  "hotkeys": {
    "open_dashboard": "ctrl+shift+s",
    "quick_generate": "ctrl+shift+g"
  }
}
