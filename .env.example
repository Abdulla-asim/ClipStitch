# clipstitch Configuration
# 
# Copy this file to .env and fill in your API keys.
# Alternatively, you can configure API keys through the Settings UI in the dashboard.
#
# Note: Environment variables take precedence over config.json values.

# OpenAI API Key
# Get your key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Google Gemini API Key
# Get your key from: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=AIzaSy...

# Ollama (local LLM)
# Ollama runs locally, no API key required
# Uncomment the line below if using Ollama locally
# OLLAMA_HOST=http://localhost:11434
